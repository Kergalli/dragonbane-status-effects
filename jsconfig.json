{
  "compilerOptions": {
    "types": ["fvtt-types"],
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": false
  },
  "include": ["scripts/**/*", "src/**/*"],
  "exclude": ["node_modules"]
}
